# Copie para .env.local e ajuste (opcional; .env.local não deve ir ao git)
#
# Desenvolvimento — URL completa da API (localhost / rede)
VITE_DEV_API_BASE_URL=http://localhost:8000/api
#
# Produção — URL completa da API (Let's Encrypt / gateway)
VITE_PRODUCTION_API_BASE_URL=https://gateway.lacosapp.com/api
#
# Quando abres o Vite por IP (10.x / 192.168.x), porta do Laravel nesse mesmo IP
VITE_LOCAL_BACKEND_PORT=8000
